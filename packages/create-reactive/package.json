{
  "name": "@growae/create-reactive",
  "version": "0.0.3",
  "type": "module",
  "bin": {
    "create-reactive": "./dist/cli.js",
    "@growae/create-reactive": "./dist/cli.js"
  },
  "main": "dist/cli.js",
  "types": "dist/cli.d.ts",
  "exports": {
    ".": {
