{
  "name": "@growae/reactive-vue",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/esm/exports/index.js",
  "types": "dist/types/exports/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/types/exports/index.d.ts",
      "default": "./dist/esm/exports/index.js"
    },
    "./query": {
      "types": "./dist/types/exports/query.d.ts",
      "default": "./dist/esm/exports/query.js"
    },
    "./nuxt": {
      "types": "./dist/types/nuxt/index.d.ts",
      "default": "./dist/esm/nuxt/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json --outDir ./dist/esm --declaration --declarationMap --declarationDir ./dist/types",
    "clean": "rm -rf dist",
    "check:types": "tsc --noEmit",
    "dev": "tsc --project tsconfig.build.json --outDir ./dist/esm --declaration --declarationMap --declarationDir ./dist/types --watch"
  },
  "dependencies": {
    "@growae/reactive": "workspace:*"
  },
  "peerDependencies": {
    "@tanstack/vue-query": ">=5.0.0",
    "nuxt": ">=3.0.0",
    "typescript": ">=5.7.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/vue-query": {
      "optional": true
    },
    "nuxt": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vue/test-utils": "^2.4.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
