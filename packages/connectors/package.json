{
  "name": "@growae/reactive-connectors",
  "version": "0.0.5",
  "type": "module",
  "main": "dist/esm/exports/index.js",
  "types": "dist/types/exports/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/types/exports/index.d.ts",
      "default": "./dist/esm/exports/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json --outDir ./dist/esm --declaration --declarationMap --declarationDir ./dist/types",
    "clean": "rm -rf dist",
    "check:types": "tsc --noEmit",
    "dev": "tsc --project tsconfig.build.json --outDir ./dist/esm --declaration --declarationMap --declarationDir ./dist/types --watch"
  },
  "dependencies": {
    "@growae/reactive": "workspace:*"
  },
  "peerDependencies": {
    "@aeternity/aepp-sdk": ">=14.0.0",
    "@ledgerhq/hw-transport": ">=6.0.0",
    "typescript": ">=5.7.0"
  },
  "peerDependenciesMeta": {
    "@ledgerhq/hw-transport": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
