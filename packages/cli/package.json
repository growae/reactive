{
  "name": "@growae/reactive-cli",
  "version": "0.0.4",
  "type": "module",
  "bin": {
    "reactive": "./dist/cli.js",
    "@growae/reactive-cli": "./dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "check:types": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@growae/reactive": "workspace:*",
    "cac": "^7.0.0",
    "chokidar": "^5.0.0"
  },
  "peerDependencies": {
    "typescript": ">=5.7.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.0"
  }
}
